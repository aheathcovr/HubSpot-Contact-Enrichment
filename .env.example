# ── Required ──────────────────────────────────────────────────────────────────

# OpenRouter API key for Perplexity Sonar research calls
OPENROUTER_API_KEY=sk-or-...

# HubSpot Private App token
HUBSPOT_API_KEY=pat-na1-...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# GCP project that owns the BigQuery tables
BQ_PROJECT_ID=gen-lang-client-0844868008

# BigQuery dataset location
BQ_LOCATION=US

# OpenRouter model slug
OPENROUTER_MODEL=perplexity/sonar-pro

# HubSpot webhook HMAC secret (from your Private App settings → Webhooks)
# Leave blank to skip signature validation during local development
HUBSPOT_WEBHOOK_SECRET=

# MillionVerifier API key for email validation before writing to HubSpot.
# If unset, validation is skipped and found emails are written as-is.
# Get your key at: https://www.millionverifier.com/api
MILLIONVERIFIER_API_KEY=

# FullEnrich API key for contact discovery fallback.
# Called when Sonar Pro + Definitive Healthcare both fail to find a facility leader.
# If unset, FullEnrich fallback is skipped.
FULLENRICH_API_KEY=

# ── Local development only ────────────────────────────────────────────────────

# GCS bucket for caching LLM responses across dev script runs.
# Set this locally to avoid redundant OpenRouter calls when re-running batch scripts.
# Leave blank (or unset) in production — Cloud Run always calls OpenRouter fresh.
GCS_CACHE_BUCKET=gen-lang-client-0844868008-llm-cache

# Path to a GCP service account key JSON file.
# On Cloud Run this is NOT needed — the attached service account provides credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
