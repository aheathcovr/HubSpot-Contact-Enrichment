# ── Required ──────────────────────────────────────────────────────────────────

# OpenRouter API key for Perplexity Sonar research calls
OPENROUTER_API_KEY=sk-or-...

# HubSpot Private App token
HUBSPOT_API_KEY=pat-na1-...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# GCP project that owns the BigQuery tables
BQ_PROJECT_ID=gen-lang-client-0844868008

# BigQuery dataset location
BQ_LOCATION=US

# OpenRouter model slug
OPENROUTER_MODEL=perplexity/sonar-pro

# HubSpot webhook HMAC secret (from your Private App settings → Webhooks)
# Leave blank to skip signature validation during local development
HUBSPOT_WEBHOOK_SECRET=

# ── Local development only ────────────────────────────────────────────────────

# Path to a GCP service account key JSON file.
# On Cloud Run this is NOT needed — the attached service account provides credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
